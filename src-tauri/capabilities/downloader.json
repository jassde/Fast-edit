{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "downloader",
  "description": "Capability for the downloader window (yt-dlp). No libmpv access needed.",
  "windows": ["downloader"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**" }]
    },
    "dialog:default"
  ]
}
